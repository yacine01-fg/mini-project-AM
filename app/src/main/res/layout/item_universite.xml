<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imgUniversite"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img_umbb" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_overlay" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvNomUniversite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Université M'Hamed Bougara"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <TextView
                android:id="@+id/tvLieuUniversite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Boumerdès, Algérie"
                android:textColor="#EEEEEE"
                android:textSize="15sp"
                android:layout_marginTop="6dp"
                android:drawableStart="@android:drawable/ic_menu_mylocation"
                android:drawablePadding="8dp"
                app:drawableTint="@color/accent_brand"/>
        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>
