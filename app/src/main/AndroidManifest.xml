<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/logo_mobguide"
        android:label="UMBB MobGuide"
        android:roundIcon="@drawable/logo_mobguide"
        android:supportsRtl="true"
        android:theme="@style/Theme.MobGuideUMBB">

        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.UniversityListActivity"
            android:label="Universités"
            android:exported="false" />

        <activity android:name=".activities.FacultyListActivity"
            android:label="Facultés"
            android:exported="false" />

        <activity android:name=".activities.DepartmentListActivity"
            android:label="Départements"
            android:exported="false" />

        <activity android:name=".activities.SearchActivity"
            android:label="Recherche"
            android:exported="false" />

        <activity android:name=".activities.ContactActivity"
            android:label="Contact"
            android:exported="false" />

    </application>

</manifest>